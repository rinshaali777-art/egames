# ─── DATABASE (MySQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=egames_db

# ─── JWT SECRET ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min32chars

# ─── SERVER ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── EMAIL (Nodemailer via Gmail) ────────────────────────────
# Use an App Password if 2FA is on: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="E-Games Tournament <your_email@gmail.com>"

# ─── FRONTEND URL (for CORS) ─────────────────────────────────
# During development: http://localhost:3000
# After deploy: https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:3000

# ─── FILE UPLOADS ────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
